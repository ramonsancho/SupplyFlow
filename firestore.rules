// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: suppliers
// Document ID: auto-generated
// Fields:
//   - id: string (required)
//   - name: string (required, 1-100 chars)
//   - document: string (required, 1-20 chars)
//   - address: string (optional, 0-200 chars)
//   - contactName: string (optional, 0-100 chars)
//   - email: string (required, valid email)
//   - phone: string (optional, 0-20 chars)
//   - families: list (required, strings, max 10 items)
//   - paymentTerms: string (optional, 0-100 chars)
//   - rating: number (optional, 0-10)
//   - accuracy: number (optional, 0-100)
//   - isCritical: bool (optional)
//   - notes: string (optional, 0-1000 chars)
//   - createdAt: timestamp (required)
//
// Collection: proposals
// Document ID: auto-generated
// Fields:
//   - id: string (required)
//   - rfqId: string (required)
//   - supplierId: string (required)
//   - supplierName: string (required)
//   - totalValue: number (required, positive)
//   - deliveryDate: string (required, valid date string)
//   - status: string (required, enum: ['pending', 'accepted', 'rejected'])
//   - items: list (required, maps, max 50 items)
//   - createdAt: timestamp (required)
//
// Collection: rfqs
// Document ID: auto-generated
// Fields:
//   - id: string (required)
//   - number: int (required)
//   - title: string (required, 1-100 chars)
//   - status: string (required, enum: ['draft', 'sent', 'closed'])
//   - desiredDate: string (optional, valid date string)
//   - items: list (required, maps, max 50 items)
//   - createdAt: timestamp (required)
//
// Collection: purchase-orders
// Document ID: auto-generated
// Fields:
//   - id: string (required)
//   - number: int (required)
//   - supplierId: string (required)
//   - supplierName: string (required)
//   - status: string (required, enum: ['draft', 'approved', 'sent', 'received', 'closed'])
//   - totalAmount: number (required, positive)
//   - originalAmount: number (optional, positive)
//   - receivedAmount: number (required, positive)
//   - receipts: list (optional, maps, max 100 items)
//   - items: list (required, maps, max 50 items)
//   - rating: number (optional, 0-10)
//   - hasRNC: bool (optional)
//   - completedAt: timestamp (optional)
//   - approvedAt: timestamp (optional)
//   - createdAt: timestamp (required)
//
// Collection: audit-logs
// Document ID: auto-generated
// Fields:
//   - id: string (required)
//   - userId: string (required)
//   - userEmail: string (required)
//   - action: string (required)
//   - entity: string (required)
//   - entityId: string (required)
//   - timestamp: timestamp (required)
//
// Collection: notifications
// Document ID: auto-generated
// Fields:
//   - id: string (required)
//   - userId: string (required)
//   - title: string (required, 1-100 chars)
//   - message: string (required, 1-500 chars)
//   - type: string (required, enum: ['info', 'success', 'warning', 'error'])
//   - read: bool (required)
//   - timestamp: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isActive() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().status == 'Ativo';
    }

    function hasRole(role) {
      return isActive() && getUserData().role == role;
    }

    function isAdmin() { return hasRole('Administrador'); }
    function isComprador() { return hasRole('Comprador'); }
    function isAprovador() { return hasRole('Aprovador'); }

    // Validation Helpers
    function isIncoming(field, type) {
      return request.resource.data[field] is type;
    }

    function affectedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // User management: 
    // - Only Admins can list all users.
    // - Individual users can only read their own document.
    match /users/{userId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      
      // All writes to users should ideally go through backend, but we allow admin to edit in UI
      // No self-promotion or self-activation
      allow create: if isAdmin();
      allow update: if (isAdmin() && request.resource.data.keys().hasOnly(['name', 'email', 'role', 'status', 'approvalLimit', 'updatedAt', 'createdBy', 'createdAt', 'deactivatedAt'])) ||
                    (isAuthenticated() && request.auth.uid == userId && affectedKeys().hasOnly(['name', 'updatedAt']));
      allow delete: if false; // Prefer deactivation
    }

    // Suppliers: strictly buyers/admins
    match /suppliers/{supplierId} {
      allow read: if isActive();
      allow create, update: if (isAdmin() || isComprador()) && 
                            request.resource.data.keys().hasOnly(['id', 'name', 'document', 'address', 'contactName', 'email', 'phone', 'families', 'paymentTerms', 'rating', 'accuracy', 'isCritical', 'notes', 'createdAt', 'updatedAt']);
      allow delete: if isAdmin();
    }

    // RFQs
    match /rfqs/{rfqId} {
      allow read: if isActive();
      allow create: if (isAdmin() || isComprador()) && 
                    request.resource.data.keys().hasOnly(['id', 'number', 'title', 'status', 'desiredDate', 'items', 'createdAt', 'updatedAt']);
      allow update: if (isAdmin() || isComprador()) && 
                    !affectedKeys().hasAny(['number']) &&
                    request.resource.data.keys().hasOnly(['id', 'number', 'title', 'status', 'desiredDate', 'items', 'createdAt', 'updatedAt']);
      allow delete: if isAdmin();
    }

    // Purchase Orders: Very Sensitive
    match /purchase-orders/{poId} {
      allow read: if isActive();
      
      // Create: Buyers/Admins only
      allow create: if (isAdmin() || isComprador()) && 
                    request.resource.data.keys().hasOnly(['id', 'number', 'supplierId', 'supplierName', 'status', 'totalAmount', 'receivedAmount', 'items', 'createdAt', 'updatedAt', 'originalAmount']);
      
      // Update: 
      // 1. Buyers can update non-status/non-approval fields when draft
      // 2. Admins can update
      // 3. Status/Approval fields are BLOCKED for all - Must use Backend API
      allow update: if (isAdmin() || isComprador()) && 
                    !affectedKeys().hasAny(['status', 'approvedBy', 'approvedByName', 'approvedAt', 'number']) &&
                    request.resource.data.keys().hasOnly(['id', 'number', 'supplierId', 'supplierName', 'status', 'totalAmount', 'receivedAmount', 'items', 'createdAt', 'updatedAt', 'originalAmount', 'receivedAmount', 'receipts', 'rating', 'hasRNC', 'completedAt', 'approvedAt', 'approvedBy', 'approvedByName']);
      
      allow delete: if isAdmin() && resource.data.status == 'draft';
    }

    // Audit Logs: BACKEND ONLY (write)
    match /audit-logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; 
    }

    // Standard Staff collections
    match /families/{familyId} {
      allow read: if isActive();
      allow write: if isAdmin() || isComprador();
    }

    match /contracts/{contractId} {
      allow read: if isActive();
      allow write: if isAdmin() || isComprador();
    }

    match /proposals/{proposalId} {
      allow read: if isActive();
      allow write: if isAdmin() || isComprador();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isActive();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && affectedKeys().hasOnly(['read']);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Catch-all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
